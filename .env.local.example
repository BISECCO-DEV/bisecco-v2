# ─── Supabase ───
# Récupère ces valeurs sur https://supabase.com → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Clé service_role (côté serveur uniquement, JAMAIS exposée au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── App ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ─── Email (Resend recommandé) ───
RESEND_API_KEY=re_xxxxx
MAIL_FROM=contact@bisecco.fr

# ─── Stripe (optionnel à ce stade) ───
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── IA Claude (chatbot) ───
ANTHROPIC_API_KEY=

# ─── Google OAuth ───
# Configuré directement dans Supabase Auth → Providers
