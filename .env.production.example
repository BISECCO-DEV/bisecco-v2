# ============================================================
# Variables d'environnement Bisecco V2 — Production o2switch
# À configurer dans cPanel : Setup Node.js App → Environment variables
# ============================================================

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...

# ─── Site ───
NEXT_PUBLIC_SITE_URL=https://bisecco.fr
NODE_ENV=production

# ─── Coming-soon (mode bypass admin) ───
COMING_SOON_ENABLED=false
COMING_SOON_BYPASS_CODE=BIS-XXXXXX

# ─── Email (Resend) ───
RESEND_API_KEY=re_xxx
MAIL_FROM=contact@bisecco.fr

# ─── Stripe (optionnel, futur) ───
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Anthropic (optionnel, chat IA) ───
ANTHROPIC_API_KEY=
